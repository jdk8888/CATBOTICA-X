# ─────────────────────────────────────────────────────────────
# CATBOTICA Smart Contracts — Environment Variables
# Copy to .env and fill in values. NEVER commit .env to git.
# Lore Anchor: LS-CATBOTICA-ANCHOR-012
# ─────────────────────────────────────────────────────────────

# ── Deployer Wallet ──
# SECURITY: Use a dedicated deployer wallet, NOT your main wallet.
# For production: Use a hardware wallet signer or KMS.
DEPLOYER_PRIVATE_KEY=

# ── Treasury Wallet (Royalty Receiver) ──
# The wallet that receives 7.5% royalties on secondary sales.
TREASURY_WALLET_ADDRESS=

# ── RPC Endpoints ──
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASE_RPC_URL=https://mainnet.base.org
SEPOLIA_RPC_URL=
ETHEREUM_RPC_URL=

# ── Block Explorer API Keys (for contract verification) ──
BASESCAN_API_KEY=
ETHERSCAN_API_KEY=

# ── Metadata URIs ──
# Base URI for ERC-1155 badge metadata (e.g., "ipfs://QmBadgeHash/")
ERC1155_BASE_URI=ipfs://PLACEHOLDER/
# Contract-level metadata for ERC-1155 collection
ERC1155_CONTRACT_URI=ipfs://PLACEHOLDER_COLLECTION/

# Base URI for SBT proof metadata
SBT_BASE_URI=ipfs://PLACEHOLDER_SBT/
# Contract-level metadata for SBT collection
SBT_CONTRACT_URI=ipfs://PLACEHOLDER_SBT_COLLECTION/

# ── Royalty Configuration ──
# Basis points: 750 = 7.5% (per LS-CATBOTICA-ANCHOR-012)
ROYALTY_BPS=750

# ── Claim / Mint Service (for airdrop) ──
# Wallet that will call mintBadge + issueProof. Set BEFORE deploy to grant MINTER_ROLE in one go.
# Or run: npx hardhat run scripts/grant-minter-role.ts --network base
CLAIM_SERVICE_WALLET=

# ── Gas Reporter ──
REPORT_GAS=false
